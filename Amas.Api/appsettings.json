{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=amas_core;Username=amas_user;Password=amas_password"
  },
  "Redis": {
    "Connection": "localhost:6379",
    "Password": ""
  },
  "MediaStorage": {
    "Provider": "Local",
    "LocalPath": "storage/media",
    "PublicBaseUrl": "/media",
    "MaxFileBytes": 5242880,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
  },
  "Jwt": {
    "Issuer": "amas-api",
    "Audience": "amas-client",
    "Secret": "",
    "ExpirationMinutes": 60
  },
  "RateLimiting": {
    "GlobalPermitLimit": 120,
    "GlobalWindowSeconds": 60,
    "LoginPermitLimit": 5,
    "LoginWindowSeconds": 60,
    "ContactPermitLimit": 3,
    "ContactWindowSeconds": 60
  },
  "ContactWebhook": {
    "Enabled": false,
    "Url": "",
    "Secret": "",
    "TimeoutSeconds": 8
  },
  "OpenAI": {
    "Enabled": true,
    "ApiKey": "",
    "Model": "gpt-4.1-mini",
    "ResponsesUrl": "https://api.openai.com/v1/responses"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
