{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=55432;Database=amas_local;Username=amas_local_user;Password=amas_local_password"
  },
  "Redis": {
    "Connection": "localhost:56379",
    "Password": "amas_local_redis_password"
  },
  "MediaStorage": {
    "Provider": "Local",
    "LocalPath": "storage/media",
    "PublicBaseUrl": "/media",
    "MaxFileBytes": 5242880,
