    "LoginWindowSeconds": 60,
    "ContactPermitLimit": 5,
    "ContactWindowSeconds": 60
  },
  "ContactWebhook": {
    "Enabled": false,
    "Url": "",
    "Secret": "",
    "TimeoutSeconds": 8
  },
  "OpenAI": {
    "Enabled": true,
    "ApiKey": "",
    "Model": "gpt-5-mini",
    "ResponsesUrl": "https://api.openai.com/v1/responses"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
